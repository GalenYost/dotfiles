# font pango:Iosevka Nerd Font 10

# autoexec
exec pipewire
exec pipewire-pulse
exec udiskie -aNT
exec mako
exec dbus-update-activation-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec blueman-applet
exec flameshot

# rules
for_window [class="flameshot"] border none, floating enable, fullscreen disable, move absolute position 0 0
for_window [title="Media viewer"] border none, floating enable, fullscreen disable, move absolute position 0 0
for_window [all] layout tabbed

set $refresh_i3status killall -SIGUSR1 i3status

bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym --locked XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym --locked XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

output eDP-1 resolution 1920x1080 position 0 0

input "type:keyboard" {
    xkb_layout us,ua,ru
    xkb_options grp:alt_shift_toggle
}

input "type:touchpad" {
    tap enabled
    natural_scroll enabled
}

set $mod Mod4

set $up k
set $down j
set $left h
set $right l

set $term foot
set $music foot -e termusic
set $files foot -e yazi ~
set $menu dmenu-wl_run -i
set $screenshot flameshot gui

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

set $bind bindsym --to-code

# apps
$bind $mod+Return exec $term
$bind $mod+c kill
$bind $mod+d exec $menu
$bind $mod+f exec $files
$bind $mod+m exec $music
$bind $mod+z exec $screenshot

# window manipulations
$bind $mod+$left focus left
$bind $mod+$down focus down
$bind $mod+$up focus up
$bind $mod+$right focus right

$bind $mod+Shift+$left move left
$bind $mod+Shift+$down move down
$bind $mod+Shift+$up move up
$bind $mod+Shift+$right move right

# splits
$bind $mod+w layout tabbed
$bind $mod+e layout toggle split

# other
$bind $mod+Shift+f floating toggle
$bind F11 fullscreen toggle global

$bind $mod+Shift+e exec loginctl suspend
$bind $mod+Shift+c reload

# workspace switch
$bind $mod+1 workspace number $ws1
$bind $mod+2 workspace number $ws2
$bind $mod+3 workspace number $ws3
$bind $mod+4 workspace number $ws4
$bind $mod+5 workspace number $ws5
$bind $mod+6 workspace number $ws6
$bind $mod+7 workspace number $ws7
$bind $mod+8 workspace number $ws8
$bind $mod+9 workspace number $ws9
$bind $mod+0 workspace number $ws10

# move to workspace
$bind $mod+Shift+1 move container to workspace number $ws1
$bind $mod+Shift+2 move container to workspace number $ws2
$bind $mod+Shift+3 move container to workspace number $ws3
$bind $mod+Shift+4 move container to workspace number $ws4
$bind $mod+Shift+5 move container to workspace number $ws5
$bind $mod+Shift+6 move container to workspace number $ws6
$bind $mod+Shift+7 move container to workspace number $ws7
$bind $mod+Shift+8 move container to workspace number $ws8
$bind $mod+Shift+9 move container to workspace number $ws9
$bind $mod+Shift+0 move container to workspace number $ws10

mode "resize" {
    bindsym $down resize grow height 10 px or 10 ppt
    bindsym $left resize shrink width 10 px or 10 ppt
    bindsym $right resize grow width 10 px or 10 ppt
    bindsym $up resize shrink height 10 px or 10 ppt
    bindsym $mod+r mode "default"
    bindsym Escape mode "default"
    bindsym Return mode "default"
}
bindsym $mod+r mode "resize"

bar {
    status_command "i3status"
    # font pango:JetBrainsMono Nerd Font 9
}
